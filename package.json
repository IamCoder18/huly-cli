{
  "name": "huly-cli-monorepo",
  "version": "0.1.4",
  "private": true,
  "description": "Monorepo for @iamcoder18/huly-cli and the huly-skill Agent Skill",
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @iamcoder18/huly-cli build",
    "dev": "pnpm --filter @iamcoder18/huly-cli dev",
    "start": "pnpm --filter @iamcoder18/huly-cli start",
    "typecheck": "pnpm -r typecheck",
    "smoke": "bash scripts/smoke.sh all"
  },
  "engines": {
    "node": ">=22.11"
  },
  "packageManager": "pnpm@10.17.1"
}