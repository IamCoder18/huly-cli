{
  "name": "@iamcoder18/huly-cli",
  "version": "0.1.7",
  "description": "AI-agent-first CLI for self-hosted Huly. Automate issues, projects, channels, docs, calendar & time tracking — no browser, no MCP, no Playwright.",
  "keywords": [
    "huly",
    "huly-cli",
    "huly platform",
    "huly sdk",
    "agent-skill",
    "openclaw",
    "ai-agent",
    "cli",
    "headless",
    "playwright-alternative",
    "mcp-alternative",
    "self-hosted",
    "project-management",
    "issue-tracker",
    "linear-cli",
    "jira-cli",
    "ci-cd",
    "automation",
    "task-management",
    "time-tracking",
    "document-management",
    "calendar",
    "terminal",
    "typescript",
    "sdk"
  ],
  "license": "AGPL-3.0-or-later",
  "homepage": "https://github.com/IamCoder18/huly-cli#readme",
  "bugs": {
    "url": "https://github.com/IamCoder18/huly-cli/issues"
  },
  "type": "module",
  "bin": {
    "huly": "./bin/huly"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "bin",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "node -e \"const fs=require('fs'); fs.copyFileSync('../../README.md','./README.md'); fs.copyFileSync('../../LICENSE','./LICENSE')\"",
    "postpublish": "node -e \"require('fs').rmSync('./README.md',{force:true}); require('fs').rmSync('./LICENSE',{force:true})\""
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/IamCoder18/huly-cli.git"
  },
  "engines": {
    "node": ">=22.13"
  },
  "dependencies": {
    "@hcengineering/account-client": "^0.7.423",
    "@hcengineering/api-client": "^0.7.423",
    "@hcengineering/core": "^0.7.423",
    "@hcengineering/text": "^0.7.423",
    "@hcengineering/text-core": "^0.7.423",
    "@hcengineering/text-markdown": "^0.7.423",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^15.0.0",
    "inquirer": "^14.0.2",
    "ora": "^9.4.1",
    "string-width": "^4.2.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/ws": "^8.5.12",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3"
  }
}
