{
  "name": "@iamcoder18/huly-cli",
  "version": "0.1.7",
  "description": "CLI and AI-agent skill for self-hosted Huly — manage issues, projects, channels, documents, calendar, time tracking, and more from the terminal or CI/CD",
  "keywords": [
    "huly",
    "huly-cli",
    "cli",
    "project-management",
    "issue-tracker",
    "self-hosted",
    "ai-agent",
    "devops",
    "ci-cd",
    "automation",
    "task-management",
    "time-tracking",
    "document-management",
    "channel",
    "calendar",
    "terminal",
    "command-line",
    "sdk"
  ],
  "type": "module",
  "bin": {
    "huly": "./bin/huly"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "node -e \"require('fs').copyFileSync('../../README.md','./README.md')\"",
    "postpublish": "node -e \"require('fs').rmSync('./README.md',{force:true})\""
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/IamCoder18/huly-cli.git"
  },
  "engines": {
    "node": ">=22.13"
  },
  "dependencies": {
    "@hcengineering/account-client": "^0.7.423",
    "@hcengineering/api-client": "^0.7.423",
    "@hcengineering/core": "^0.7.423",
    "@hcengineering/text": "^0.7.423",
    "@hcengineering/text-core": "^0.7.423",
    "@hcengineering/text-markdown": "^0.7.423",
    "chalk": "^5.3.0",
    "commander": "^15.0.0",
    "inquirer": "^14.0.2",
    "ora": "^9.4.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/ws": "^8.5.12",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3"
  }
}
